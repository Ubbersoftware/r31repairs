rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner() { return isSignedIn() && request.auth.token.role == 'owner'; }
    function isSelf(uid) { return isSignedIn() && request.auth.uid == uid; }

    match /r31_users/{uid} {
      allow read: if isSelf(uid) || isOwner();
      allow create: if isSelf(uid) && request.resource.data.role == 'customer';
      allow update: if (isSelf(uid) && request.resource.data.role == resource.data.role) || isOwner();
      allow delete: if false;
    }
    match /r31_services/{id}    { allow read: if true; allow write: if isOwner(); }
    match /r31_phoneModels/{id} { allow read: if true; allow write: if isOwner(); }
    match /r31_prices/{id}      { allow read: if true; allow write: if isOwner(); }
    match /r31_faqs/{id}        { allow read: if true; allow write: if isOwner(); }
    match /r31_settings/{id} {
      allow read: if true;
      allow write: if false; // updateSettingsAction only
    }

    match /r31_orders/{orderId} {
      allow read: if isOwner() || (request.auth != null && request.auth.uid == resource.data.customerId);
      allow write: if false; // all writes via Admin SDK server actions
      match /events/{eventId} {
        allow read: if isOwner()
          || (resource.data.visibility == 'customer'
              && request.auth != null
              && get(/databases/$(database)/documents/r31_orders/$(orderId)).data.customerId == request.auth.uid);
        allow write: if false;
      }
    }
    match /r31_invoices/{id} {
      allow read: if isOwner() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow write: if false; // all writes via Admin SDK server actions
    }
    match /r31_warranties/{id} {
      allow read: if isOwner() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow write: if false; // Admin-SDK server actions only
      match /claims/{claimId} {
        allow read: if isOwner()
          || (isSignedIn() && get(/databases/$(database)/documents/r31_warranties/$(id)).data.customerId == request.auth.uid);
        allow write: if false; // raiseClaimAction + updateClaimAction via Admin-SDK
      }
    }
    match /r31_notifications/{notifId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow update: if request.auth != null
        && request.auth.uid == resource.data.userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if false;
    }
    match /r31_counters/{id} { allow read, write: if false; }
  }
}
